# Copy to .env.dev and adjust. All values are dev-only defaults.

# Postgres (shared by hub-db + user-server-db services; separate DBs)
POSTGRES_USER=artic
POSTGRES_PASSWORD=artic
POSTGRES_DB=artic

# Hub runtime
DATABASE_URL=postgresql+asyncpg://artic:artic@hub-db:5432/artic
INTERNAL_SECRET=artic-dev-secret
JWT_SECRET=artic-jwt-dev-secret
TWELVE_DATA_API_KEY=

# Wallet auth
AUTH_MESSAGE_DOMAIN=artic.trade
AUTH_NONCE_TTL_SECONDS=300
AUTH_SESSION_TTL_SECONDS=28800
AUTH_SUPPORTED_CHAINS=initia-testnet

# Initia .init name service (leave blank to disable .init lookup)
INITIA_NAME_SERVICE_URL=

# user-server runtime
HUB_URL=http://hub:9000
USER_ID=00000000-0000-0000-0000-000000000000
USER_TOKEN=dev-token
HUB_SECRET=artic-dev-hub-secret
INTERNAL_SECRET=artic-dev-internal-secret
AGENT_IMAGE=artic-app:dev
OTEL_EXPORTER_OTLP_ENDPOINT=

# Morph VM
MORPH_API_KEY=
MORPH_BASE_URL=https://cloud.morph.so
# Morph blank base snapshot (provider-supplied or one-time created)
BASE_SNAPSHOT_ID=
# Output of scripts/build_golden_snapshot.py — paste after build
MORPH_GOLDEN_SNAPSHOT_ID=
# Tag for baked-in images (artic-agent / artic-user-server local docker tag)
VM_IMAGE_TAG=v0
# Publicly reachable hub URL (Morph VM curls this to pull image tarballs)
HUB_PUBLIC_URL=
